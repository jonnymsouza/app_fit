# ─── Banco de dados (Neon PostgreSQL) ───────────────────────────────────────
# Obtenha em: https://console.neon.tech → seu projeto → Connection string
# DATABASE_URL: conexão via pooler (usar no app)
# DIRECT_URL:   conexão direta (usar para prisma db push / migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gere um secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-longa"
# Em produção: URL do Vercel (ex: https://seuapp.vercel.app)
# Em dev: http://localhost:3000
NEXTAUTH_URL="https://seuapp.vercel.app"
